# --- Broker Settings ---
# Overriding the default port from 8000 in config.yaml to 8005.
BROKER_PORT=8005

# --- Worker Settings ---
# URL where the worker can reach the broker. This is environment-specific.
BROKER_URL=http://<BROKER_HOST>:8005

# URL where the worker can reach its local Ollama instance.
OLLAMA_URL=http://localhost:11434

# --- Global Settings ---
# Set to "DEBUG" for more verbose output.
LOG_LEVEL=INFO
