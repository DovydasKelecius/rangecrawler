# RangeCrawler Dynamic Configuration

# --- Broker Settings ---
# Host and port for the broker to bind to.
BROKER_HOST=0.0.0.0
BROKER_PORT=8005

# Optional: URL to fetch a dynamic port from (for range-based assignments).
BROKER_PORT_ASSIGNMENT_URL=

# Database file location.
DATABASE_PATH=rangecrawler.db

# --- Worker Settings ---
# URL where the worker can reach the broker.
BROKER_URL=http://localhost:8000

# URL where the worker can reach the Ollama instance.
OLLAMA_URL=http://localhost:11434

# --- Agent Settings ---
# Default iterations for the autonomous agent loop.
AGENT_MAX_ITERATIONS=15
AGENT_DEFAULT_TIMEOUT=120
AGENT_WORKING_DIR=./agent_workspace

# --- Global Settings ---
LOG_LEVEL=INFO
DEBUG=false
